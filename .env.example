# 将此文件复制为 .env，然后填入你的真实凭据
# cp .env.example .env

STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# 首次运行 python manage.py sync_strava 授权成功后，可将以下三行填入
# 支持网页端「更新数据」与定时任务自动同步（access_token 过期会自动用 refresh_token 续期）
# STRAVA_ACCESS_TOKEN=
# STRAVA_REFRESH_TOKEN=
# STRAVA_EXPIRES_AT=
